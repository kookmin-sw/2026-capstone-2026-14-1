<script>
(function initGuestAnimations() {
  // Fade-in observer for sections and cards
  const fadeEls = document.querySelectorAll(
    '.guest-scroll-section .guest-section-head,' +
    '.guest-scroll-section .guest-info-card,' +
    '.guest-scroll-section .guest-feature-card,' +
    '.guest-scroll-section .guest-panel,' +
    '.guest-scroll-section .guest-process-graph article,' +
    '.guest-scroll-section .guest-trust-grid article,' +
    '.guest-scroll-section .guest-problem-grid,' +
    '.guest-scroll-section .guest-feature-grid,' +
    '.guest-scroll-section .guest-flow-board,' +
    '.guest-login-band > div'
  );

  fadeEls.forEach(function(el) {
    el.classList.add('guest-fade-in');
  });

  var scrollRoot = document.querySelector('.guest-scroll-container');
  var fadeObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('guest-visible');
      }
    });
  }, { threshold: 0.15, root: scrollRoot.scrollHeight > scrollRoot.clientHeight ? scrollRoot : null });

  fadeEls.forEach(function(el, i) {
    el.style.transitionDelay = Math.min(i % 4 * 80, 240) + 'ms';
    fadeObserver.observe(el);
  });

  // Progress bar animation
  var progressBars = document.querySelectorAll('.guest-progress span');
  var progObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.transform = 'scaleX(1)';
      }
    });
  }, { threshold: 0.5 });
  progressBars.forEach(function(bar) {
    bar.style.transformOrigin = 'left';
    bar.style.transform = 'scaleX(0)';
    bar.style.transition = 'transform 1.5s cubic-bezier(0.2,0.8,0.2,1) 0.8s';
    progObserver.observe(bar);
  });
})();
</script>

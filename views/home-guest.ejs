<style>
  /* ── Scroll-snap: one section per scroll ── */
  .guest-scroll-container {
    gap: 0 !important;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    height: 100vh;
    height: 100svh;
    margin: -32px;
    padding: 0;
  }
  .guest-scroll-section {
    scroll-snap-align: start;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(32px, 5vw, 64px) clamp(24px, 4vw, 56px);
    box-sizing: border-box;
  }
  .guest-scroll-section.guest-index-hero {
    flex-direction: row;
    align-items: center;
    gap: 28px;
  }

  /* ── Fade-in on scroll ── */
  .guest-fade-in {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .guest-fade-in.guest-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Hero Animations (from index.html) ── */
  @keyframes guestSquatMotion {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(12px); }
  }
  @keyframes guestScanline {
    0% { transform: translateY(-50px); opacity: 0; }
    50% { opacity: 0.6; }
    100% { transform: translateY(370px); opacity: 0; }
  }
  @keyframes guestLift {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }
  @keyframes guestGlowSpin {
    to { transform: rotate(360deg); }
  }
  @keyframes guestPulseScore {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  @keyframes guestFloat {
    0%, 100% { transform: translate3d(0,0,0) scale(1); }
    50% { transform: translate3d(0,-20px,0) scale(1.03); }
  }
  .guest-stickman-squat {
    animation: guestSquatMotion 3s ease-in-out infinite;
  }
  .guest-camera-area::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: #38bdf8;
    box-shadow: 0 0 20px #38bdf8;
    animation: guestScanline 3s linear infinite;
    z-index: 10;
  }
  .guest-dashboard-card {
    animation: guestLift 5.5s ease-in-out infinite;
  }
  .guest-glow-ring {
    position: absolute;
    width: 480px;
    height: 480px;
    border-radius: 999px;
    background:
      radial-gradient(circle, rgba(56,189,248,0.18), transparent 60%),

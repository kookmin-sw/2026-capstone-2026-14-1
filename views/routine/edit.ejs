<div class="page active">
  <section class="page-header">
    <div>
      <h1><%= isNew ? '새 루틴 만들기' : '루틴 수정' %></h1>
      <p class="muted">운동 순서, 목표 기준, 세트/휴식 시간을 설정하세요</p>
    </div>
    <div class="actions">
      <a href="/routine" class="ghost">← 돌아가기</a>
    </div>
  </section>

  <form id="routineForm" class="grid two">
    <div class="card">
      <h3>루틴 정보</h3>
      <div class="form-group">
        <label for="routineName">루틴 이름</label>
        <input
          type="text"
          id="routineName"
          name="name"
          maxlength="100"
          placeholder="예: 전신 근력 루틴 A"
          value="<%= routine ? routine.name : '' %>"
          required
        />
      </div>
    </div>

    <div class="card">
      <h3>운동 추가</h3>
      <div class="form-group">
        <label for="exerciseSelect">운동 선택</label>
        <select id="exerciseSelect" class="form-select">
          <option value="">운동을 선택하세요</option>
          <% exercises.forEach((exercise) => { %>
            <option
              value="<%= exercise.exercise_id %>"
              data-name="<%= exercise.name %>"
              data-default-target="<%= exercise.default_target_type === 'TIME' ? 'TIME' : 'REPS' %>">
              <%= exercise.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="grid two" style="gap: 12px;">
        <div class="form-group">
          <label for="targetType">목표 유형</label>
          <select id="targetType">
            <option value="REPS">횟수</option>
            <option value="TIME">시간(초)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="targetValue">목표 값</label>
          <input type="number" id="targetValue" value="10" min="1" />
        </div>
        <div class="form-group">
          <label for="setsCount">세트 수</label>
          <input type="number" id="setsCount" value="3" min="1" />
        </div>
        <div class="form-group">
          <label for="restSec">휴식 시간(초)</label>
          <input type="number" id="restSec" value="30" min="0" />
        </div>
      </div>

      <button type="button" class="primary full" onclick="addStep()">+ 운동 추가</button>
    </div>
  </form>

  <div class="card">
    <div class="card-header">
      <h3>운동 순서</h3>
      <span class="muted" id="stepCount">0개의 운동</span>
    </div>
    <div id="stepsList" class="step-list">
      <p class="muted" id="emptyMessage">운동을 추가해주세요</p>
    </div>
  </div>

  <div class="card" style="flex-direction: row; justify-content: flex-end; gap: 10px;">
    <a href="/routine" class="ghost">취소</a>
    <button type="button" class="primary" onclick="saveRoutine()">
      <%= isNew ? '루틴 저장' : '변경사항 저장' %>
    </button>
  </div>
</div>

<style>
  .form-select,
  .form-group select,
  .form-group input {
    width: 100%;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--input-bg);
    color: var(--text);
  }

  .step-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .step-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--input-bg);
  }

  .step-order {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--primary);
    color: #fff;
    display: grid;
    place-items: center;
    font-weight: 700;
    flex-shrink: 0;
  }

  .step-info {
    flex: 1;
  }

  .step-info h4 {
    margin: 0 0 4px 0;
  }

  .step-actions {
    display: flex;
    gap: 8px;
  }

  .step-actions button {
    padding: 6px 10px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-size: 14px;
  }

  .move-btn {
    background: var(--ghost-bg, #e2e8f0);
    color: var(--text);
  }

  .move-btn:hover {
    background: var(--border, #cbd5e1);
  }

  .remove-btn {
    background: rgba(255, 92, 109, 0.1);
    color: var(--danger);
  }

  .remove-btn:hover {
    background: rgba(255, 92, 109, 0.2);
  }
</style>

<script>
  const exercises = <%- JSON.stringify(exercises || []) %>;
  const existingRoutine = <%- routine ? JSON.stringify(routine) : 'null' %>;
  const isNew = <%= isNew ? 'true' : 'false' %>;

  let steps = [];

  const getUnitLabel = (targetType) => (targetType === 'TIME' ? '초' : '회');

  function normalizeTargetType(value) {
    const normalized = String(value || '').toUpperCase();
    if (normalized === 'DURATION') return 'TIME';
    return normalized === 'TIME' ? 'TIME' : 'REPS';
  }

  function clampInt(value, fallback, min) {
    const parsed = Number(value);
    if (!Number.isFinite(parsed)) return fallback;
    return Math.max(min, Math.round(parsed));
  }

  function hydrateExistingRoutine() {
    if (!existingRoutine || !Array.isArray(existingRoutine.routine_setup)) return;

    steps = existingRoutine.routine_setup.map((step) => ({
      exercise_id: Number(step.exercise?.exercise_id || 0),
      exercise_name: step.exercise?.name || '운동',
      target_type: normalizeTargetType(step.target_type),
      target_value: clampInt(step.target_value, 10, 1),
      sets: clampInt(step.sets, 3, 1),
      rest_sec: clampInt(step.rest_sec, 30, 0)
    })).filter((step) => step.exercise_id > 0);

    renderSteps();
  }

  function applyExerciseDefaultTarget() {
    const select = document.getElementById('exerciseSelect');
    const targetTypeEl = document.getElementById('targetType');
    if (!select || !targetTypeEl) return;

    const option = select.options[select.selectedIndex];
    if (!option) return;

    const defaultTarget = normalizeTargetType(option.dataset.defaultTarget);
    targetTypeEl.value = defaultTarget;

    const targetValueEl = document.getElementById('targetValue');
    if (targetValueEl && Number(targetValueEl.value) <= 0) {
      targetValueEl.value = defaultTarget === 'TIME' ? '30' : '10';
    }
  }

  function addStep() {
    const select = document.getElementById('exerciseSelect');
    const selectedId = Number(select.value);
    const selectedOption = select.options[select.selectedIndex];

    if (!Number.isFinite(selectedId) || selectedId <= 0 || !selectedOption) {
      alert('운동을 선택해주세요.');
      return;
    }

    const targetType = normalizeTargetType(document.getElementById('targetType').value);
    const targetValue = clampInt(document.getElementById('targetValue').value, targetType === 'TIME' ? 30 : 10, 1);
    const sets = clampInt(document.getElementById('setsCount').value, 3, 1);
    const restSec = clampInt(document.getElementById('restSec').value, 30, 0);

    steps.push({
      exercise_id: selectedId,
      exercise_name: selectedOption.dataset.name || '운동',
      target_type: targetType,
      target_value: targetValue,
      sets,
      rest_sec: restSec
    });

    renderSteps();

    select.value = '';
    document.getElementById('targetValue').value = targetType === 'TIME' ? '30' : '10';
    document.getElementById('setsCount').value = '3';
    document.getElementById('restSec').value = '30';
  }

  function removeStep(index) {
    steps.splice(index, 1);
    renderSteps();
  }

  function moveStep(index, direction) {
    const nextIndex = index + direction;
    if (nextIndex < 0 || nextIndex >= steps.length) return;

    const temp = steps[index];
    steps[index] = steps[nextIndex];
    steps[nextIndex] = temp;
    renderSteps();
  }

  function renderSteps() {
    const container = document.getElementById('stepsList');
    const stepCountEl = document.getElementById('stepCount');

    if (!steps.length) {
      container.innerHTML = '<p class="muted" id="emptyMessage">운동을 추가해주세요</p>';
      stepCountEl.textContent = '0개의 운동';
      return;
    }

    stepCountEl.textContent = `${steps.length}개의 운동`;
    container.innerHTML = steps.map((step, index) => {
      const targetLabel = `${step.target_value}${getUnitLabel(step.target_type)}`;
      const restLabel = step.rest_sec > 0 ? `(휴식 ${step.rest_sec}초)` : '';

      return `
        <div class="step-item" data-index="${index}">
          <div class="step-order">${index + 1}</div>
          <div class="step-info">
            <h4>${step.exercise_name}</h4>
            <p class="muted">${targetLabel} × ${step.sets}세트 ${restLabel}</p>
          </div>
          <div class="step-actions">
            <button type="button" class="move-btn" onclick="moveStep(${index}, -1)" ${index === 0 ? 'disabled' : ''}>↑</button>
            <button type="button" class="move-btn" onclick="moveStep(${index}, 1)" ${index === steps.length - 1 ? 'disabled' : ''}>↓</button>
            <button type="button" class="remove-btn" onclick="removeStep(${index})">✕</button>
          </div>
        </div>
      `;
    }).join('');
  }

  async function saveRoutine() {
    const name = String(document.getElementById('routineName').value || '').trim();

    if (!name) {
      alert('루틴 이름을 입력해주세요.');
      return;
    }

    if (!steps.length) {
      alert('최소 1개의 운동을 추가해주세요.');
      return;
    }

    const payload = {
      name,
      steps: steps.map((step) => ({
        exercise_id: step.exercise_id,
        target_type: step.target_type,
        target_value: step.target_value,
        sets: step.sets,
        rest_sec: step.rest_sec
      }))
    };

    try {
      const url = isNew ? '/api/routine' : `/api/routine/${existingRoutine.routine_id}`;
      const method = isNew ? 'POST' : 'PUT';

      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.success) {
        alert(data.error || '저장에 실패했습니다.');
        return;
      }

      window.location.href = '/routine';
    } catch (error) {
      console.error('Save routine failed:', error);
      alert('저장 중 오류가 발생했습니다.');
    }
  }

  document.getElementById('exerciseSelect').addEventListener('change', applyExerciseDefaultTarget);
  hydrateExistingRoutine();

  window.addStep = addStep;
  window.removeStep = removeStep;
  window.moveStep = moveStep;
  window.saveRoutine = saveRoutine;
</script>


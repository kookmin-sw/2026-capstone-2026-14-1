<%
  const modeLabelMap = { FREE: '자율 운동', ROUTINE: '루틴 운동', LEARN: '학습 모드' };
  const statusLabelMap = { DONE: '완료', ABORTED: '중단' };
  const viewLabelMap = { FRONT: '정면', SIDE: '측면', DIAGONAL: '대각선' };

  const formatDuration = (seconds) => {
    const safe = Math.max(0, Number(seconds) || 0);
    const mins = Math.floor(safe / 60);
    const remain = safe % 60;
    return `${mins}분 ${remain}초`;
  };

  const formatResultValue = (session) => {
    const basis = String(session?.result_basis || '').toUpperCase();
    const unit = String(session?.total_result_unit || '').toUpperCase();
    const value = Math.max(0, Number(session?.total_result_value) || 0);
    if (basis === 'REPS' || unit === 'COUNT') return `${value}회`;
    if (basis === 'DURATION' || unit === 'SEC') return `${value}초`;
    return `${value}`;
  };

  const scoreTier = (score, status) => {
    if (String(status || '').toUpperCase() === 'ABORTED') return 'aborted';
    const safe = Math.max(0, Number(score) || 0);
    if (safe >= 85) return 'excellent';
    if (safe >= 70) return 'good';
    if (safe >= 50) return 'fair';
    return 'weak';
  };
%>

<link rel="stylesheet" href="/history-v2.css" />

<div class="page active history-v2-page">
  <section class="page-header">
    <div>
      <h1>운동 히스토리</h1>
      <p class="muted">신규 DB(세션 + 스냅샷) 기준 기록 뷰</p>
    </div>
  </section>

  <section class="history-overview-grid">
    <article class="card overview-card">
      <span class="overview-label">연속 운동</span>
      <strong class="overview-value"><%= stats.overview.streak %>일</strong>
      <span class="overview-meta">기록 유지 중</span>
    </article>
    <article class="card overview-card">
      <span class="overview-label">최근 30일</span>
      <strong class="overview-value"><%= stats.recent30.count %>회</strong>
      <span class="overview-meta"><%= stats.recent30.totalMinutes %>분 · 평균 <%= stats.recent30.avgScore %>점</span>
    </article>
    <article class="card overview-card">
      <span class="overview-label">오늘</span>
      <strong class="overview-value"><%= stats.today.count %>회</strong>
      <span class="overview-meta"><%= stats.today.totalMinutes %>분 · <%= stats.today.totalReps %>회</span>
    </article>
    <article class="card overview-card">
      <span class="overview-label">이번 주</span>
      <strong class="overview-value"><%= stats.week.count %>회</strong>
      <span class="overview-meta"><%= stats.week.totalMinutes %>분 · 평균 <%= stats.week.avgScore %>점</span>
    </article>
    <article class="card overview-card">
      <span class="overview-label">누적 세션</span>
      <strong class="overview-value"><%= stats.overview.doneCount %>회</strong>
      <span class="overview-meta">중단 <%= stats.overview.abortedCount %>회</span>
    </article>
    <article class="card overview-card">
      <span class="overview-label">최고 점수</span>
      <% if (stats.overview.best) { %>
        <strong class="overview-value"><%= Math.round(stats.overview.best.final_score || 0) %>점</strong>
        <span class="overview-meta"><%= stats.overview.best.exercise?.name || '운동' %></span>
      <% } else { %>
        <strong class="overview-value">-</strong>
        <span class="overview-meta">기록 없음</span>
      <% } %>
    </article>
  </section>

  <section class="card insight-panel">
    <div class="insight-header">
      <div>
        <h2 class="insight-title">기록 인사이트</h2>
        <p class="muted">일별 추이와 운동별 분포</p>
      </div>
      <div class="range-switch" role="group" aria-label="기간 선택">
        <button type="button" class="range-btn" data-range="7">7일</button>
        <button type="button" class="range-btn active" data-range="30">30일</button>
        <button type="button" class="range-btn" data-range="90">90일</button>
      </div>
    </div>

    <div class="insight-metrics" id="insightMetrics"></div>
    <div class="insight-charts">
      <div class="chart-panel">
        <div class="chart-header-row">
          <h3>평균 점수 추이</h3>
          <span id="scoreTrendHint" class="trend-hint">집계 중...</span>
        </div>
        <div id="scoreChart" class="chart-wrap" aria-live="polite"></div>
      </div>
      <div class="chart-panel">
        <div class="chart-header-row">
          <h3>운동 시간 추이</h3>
          <span id="timeTrendHint" class="trend-hint">집계 중...</span>
        </div>
        <div id="timeChart" class="chart-wrap" aria-live="polite"></div>
      </div>
    </div>
    <div class="exercise-breakdown">
      <div class="chart-header-row"><h3>운동별 분포</h3></div>
      <div class="exercise-breakdown-list" id="exerciseBreakdown"></div>
    </div>
  </section>

  <section class="card filter-card">
    <form method="GET" action="/history" class="filter-form">
      <div class="filter-group">
        <label for="historyExercise">운동</label>
        <select id="historyExercise" name="exercise" onchange="this.form.submit()">
          <option value="all">전체</option>
          <% exercises.forEach((exercise) => { %>
            <option value="<%= exercise.exercise_id %>" <%= String(exercise.exercise_id) === String(filters.exercise) ? 'selected' : '' %>>
              <%= exercise.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="filter-group">
        <label for="historyPeriod">기간</label>
        <select id="historyPeriod" name="period" onchange="this.form.submit()">
          <option value="all" <%= filters.period === 'all' ? 'selected' : '' %>>전체</option>
          <option value="today" <%= filters.period === 'today' ? 'selected' : '' %>>오늘</option>
          <option value="week" <%= filters.period === 'week' ? 'selected' : '' %>>이번 주</option>
          <option value="month" <%= filters.period === 'month' ? 'selected' : '' %>>이번 달</option>
          <option value="90d" <%= filters.period === '90d' ? 'selected' : '' %>>최근 90일</option>
        </select>
      </div>
      <div class="filter-group">
        <label for="historyStatus">상태</label>
        <select id="historyStatus" name="status" onchange="this.form.submit()">
          <option value="DONE" <%= filters.status === 'DONE' ? 'selected' : '' %>>완료</option>
          <option value="ABORTED" <%= filters.status === 'ABORTED' ? 'selected' : '' %>>중단</option>
          <option value="ALL" <%= filters.status === 'ALL' ? 'selected' : '' %>>전체</option>
        </select>
      </div>
      <div class="filter-group">
        <label for="historySort">정렬</label>
        <select id="historySort" name="sort" onchange="this.form.submit()">
          <option value="latest" <%= filters.sort === 'latest' ? 'selected' : '' %>>최신순</option>
          <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>오래된순</option>
          <option value="score" <%= filters.sort === 'score' ? 'selected' : '' %>>점수 높은순</option>
        </select>
      </div>
    </form>
  </section>

  <section class="history-list-section">
    <% if (!sessions || sessions.length === 0) { %>
      <div class="card empty-state">
        <h3>조건에 맞는 기록이 없습니다</h3>
        <p class="muted">필터를 바꾸거나 새 운동을 시작해보세요.</p>
        <div class="empty-actions">
          <a class="primary" href="/workout/free">자율 운동 시작</a>
          <a class="ghost" href="/routine">루틴 보러가기</a>
        </div>
      </div>
    <% } else { %>
      <div class="history-list">
        <% sessions.forEach((session) => { %>
          <article class="card history-row <%= String(session.status || '').toUpperCase() === 'ABORTED' ? 'is-aborted' : '' %>" data-session-id="<%= session.session_id %>">
            <div class="history-row-main">
              <div class="history-row-top">
                <span class="history-date">
                  <%= new Date(session.started_at).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                  <span class="history-time"><%= new Date(session.started_at).toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit' }) %></span>
                </span>
                <div class="history-badges">
                  <span class="badge mode"><%= modeLabelMap[session.mode] || session.mode || '-' %></span>
                  <span class="badge status <%= String(session.status || '').toLowerCase() %>"><%= statusLabelMap[session.status] || session.status || '-' %></span>
                  <span class="badge view"><%= viewLabelMap[session.selected_view] || session.selected_view || '-' %></span>
                </div>
              </div>
              <h3 class="history-title"><%= session.exercise?.name || '운동' %></h3>
              <div class="history-facts">
                <span class="fact-chip">결과 <strong><%= formatResultValue(session) %></strong></span>
                <span class="fact-chip">운동 시간 <strong><%= formatDuration(session.duration_sec) %></strong></span>
                <% if (session.final_snapshot) { %>
                  <span class="fact-chip">FINAL #<strong><%= session.final_snapshot.snapshot_no %></strong></span>
                <% } %>
              </div>
              <% if (session.summary_feedback) { %>
                <p class="history-feedback"><%= session.summary_feedback %></p>
              <% } %>
            </div>
            <div class="history-row-score">
              <div class="score-bubble <%= scoreTier(session.final_score, session.status) %>">
                <strong><%= String(session.status || '').toUpperCase() === 'ABORTED' ? '-' : Math.round(session.final_score || 0) %></strong>
                <span>점수</span>
              </div>
            </div>
            <div class="history-row-actions">
              <button type="button" class="ghost small" onclick="viewDetail('<%= session.session_id %>')">상세</button>
              <% if (String(session.status || '').toUpperCase() === 'DONE') { %>
                <a class="ghost small link-btn" href="/workout/result/<%= session.session_id %>">결과</a>
              <% } %>
              <button type="button" class="danger small" onclick="deleteSession('<%= session.session_id %>')">삭제</button>
            </div>
          </article>
        <% }) %>
      </div>

      <% if (pagination.totalPages > 1) { %>
        <nav class="pagination" aria-label="페이지 이동">
          <% if (pagination.page > 1) { %>
            <a class="page-btn" href="?page=<%= pagination.page - 1 %>&exercise=<%= filters.exercise %>&period=<%= filters.period %>&status=<%= filters.status %>&sort=<%= filters.sort %>">이전</a>
          <% } %>
          <span class="page-info"><%= pagination.page %> / <%= pagination.totalPages %> · 총 <%= pagination.total %>개</span>
          <% if (pagination.page < pagination.totalPages) { %>
            <a class="page-btn" href="?page=<%= pagination.page + 1 %>&exercise=<%= filters.exercise %>&period=<%= filters.period %>&status=<%= filters.status %>&sort=<%= filters.sort %>">다음</a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </section>
</div>

<div class="modal" id="detailModal" hidden>
  <div class="modal-content history-detail-modal">
    <div class="modal-header">
      <h2 id="detailModalTitle">세션 상세</h2>
      <button type="button" class="icon" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body" id="detailModalBody">
      <div class="loading-state">불러오는 중...</div>
    </div>
  </div>
</div>

<script>
  window.__HISTORY_BOOTSTRAP__ = {
    initialDays: 30
  };
</script>
<script src="/js/history-page.js"></script>


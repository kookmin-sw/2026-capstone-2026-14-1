<%
  const modeLabelMap = { FREE: '자율 운동', ROUTINE: '루틴 운동', LEARN: '학습 모드' };
  const statusLabelMap = { DONE: '완료', ABORTED: '중단', ALL: '전체' };
  const viewLabelMap = { FRONT: '정면', SIDE: '측면', DIAGONAL: '대각선', ROUTINE: '루틴' };
  const periodLabelMap = {
    all: '전체 기간',
    today: '오늘',
    week: '이번 주',
    month: '이번 달',
    '90d': '최근 90일'
  };
  const sortLabelMap = {
    latest: '최신순',
    oldest: '오래된순',
    score: '점수 높은순'
  };

  const safeSessions = Array.isArray(sessions) ? sessions : [];
  const safeExercises = Array.isArray(exercises) ? exercises : [];

  const formatDuration = (seconds) => {
    const safe = Math.max(0, Number(seconds) || 0);
    const mins = Math.floor(safe / 60);
    const remain = safe % 60;
    return `${mins}분 ${remain}초`;
  };

  const formatResultValue = (session) => {
    const basis = String(session?.result_basis || '').toUpperCase();
    const unit = String(session?.total_result_unit || '').toUpperCase();
    const value = Math.max(0, Number(session?.total_result_value) || 0);
    if (basis === 'REPS' || unit === 'COUNT') return `${value}회`;
    if (basis === 'DURATION' || unit === 'SEC') return `${value}초`;
    return `${value}`;
  };

  const scoreTier = (score, status) => {
    if (String(status || '').toUpperCase() === 'ABORTED') return 'aborted';
    const safe = Math.max(0, Number(score) || 0);
    if (safe >= 85) return 'excellent';
    if (safe >= 70) return 'good';
    if (safe >= 50) return 'fair';
    return 'weak';
  };

  const doneSessions = safeSessions.filter((session) => String(session?.status || '').toUpperCase() === 'DONE');
  const abortedSessions = safeSessions.filter((session) => String(session?.status || '').toUpperCase() === 'ABORTED');
  const pageAvgScore = safeSessions.length
    ? Math.round(safeSessions.reduce((sum, session) => sum + Math.max(0, Number(session?.final_score) || 0), 0) / safeSessions.length)
    : 0;
  const lowAccuracyCount = doneSessions.filter((session) => Math.max(0, Number(session?.final_score) || 0) < 70).length;

  const selectedExercise = safeExercises.find((exercise) => String(exercise.exercise_id) === String(filters.exercise));
  const filterSummary = [
    selectedExercise?.name || (filters.exercise === 'all' ? '전체 운동' : '선택 운동'),
    periodLabelMap[filters.period] || '전체 기간',
    statusLabelMap[filters.status] || '상태 필터',
    sortLabelMap[filters.sort] || '최신순'
  ].join(' · ');

  const toFocusPreview = (session) => {
    const preview = session?.focus_preview || {};
    return {
      headline: preview.headline || '세션 데이터를 기반으로 개선 방향을 정리하는 중입니다.',
      issue: preview.primary_issue || '핵심 문제 추출 중',
      action: preview.primary_action || '다음 세션에서 동일 동작을 천천히 반복해 보세요.'
    };
  };

  const isRoutineItem = (item) => String(item?.item_type || '').toUpperCase() === 'ROUTINE_RUN';
%>

<link rel="stylesheet" href="/history-v2.css?v=3" />

<div class="page active history-v3-page history-focus-page">
  <section class="card history-focus-header">
    <div class="history-focus-intro">
      <p class="history-hero-kicker">Posture Accuracy Only</p>
      <h1>운동 히스토리</h1>
      <p class="history-hero-description">
        나의 운동 자세의 정확도가 어떻게 변해왔는지, 그리고 어떤 부분을 개선하면 좋을지 히스토리를 통해 확인해보세요.
      </p>
      <p class="muted history-filter-summary">현재 보기: <strong><%= filterSummary %></strong></p>
    </div>

    <div class="history-focus-summary">
      <article class="focus-summary-card">
        <span>표시 세션</span>
        <strong id="visibleSessionCount"><%= safeSessions.length %></strong>
        <small>현재 페이지 기준</small>
      </article>
      <article class="focus-summary-card">
        <span>완료 세션</span>
        <strong id="visibleDoneCount"><%= doneSessions.length %></strong>
        <small>중단 <span id="visibleAbortedCount"><%= abortedSessions.length %></span>회</small>
      </article>
      <article class="focus-summary-card">
        <span>평균 정확도</span>
        <strong id="visibleAvgScore"><%= pageAvgScore %>점</strong>
        <small>전체 세션 평균</small>
      </article>
      <article class="focus-summary-card">
        <span>개선 집중 대상</span>
        <strong><%= lowAccuracyCount %>회</strong>
        <small>70점 미만 세션</small>
      </article>
    </div>
  </section>

  <section class="card history-filter-card">
    <div class="history-filter-header">
      <h2>기록 필터</h2>
      <p class="muted">필터 변경 시 자동으로 다시 조회됩니다.</p>
    </div>
    <form method="GET" action="/history" class="history-filter-form">
      <div class="filter-field">
        <label for="historyExercise">운동</label>
        <select id="historyExercise" name="exercise" onchange="this.form.submit()">
          <option value="all">전체</option>
          <% safeExercises.forEach((exercise) => { %>
            <option value="<%= exercise.exercise_id %>" <%= String(exercise.exercise_id) === String(filters.exercise) ? 'selected' : '' %>>
              <%= exercise.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="filter-field">
        <label for="historyPeriod">기간</label>
        <select id="historyPeriod" name="period" onchange="this.form.submit()">
          <option value="all" <%= filters.period === 'all' ? 'selected' : '' %>>전체</option>
          <option value="today" <%= filters.period === 'today' ? 'selected' : '' %>>오늘</option>
          <option value="week" <%= filters.period === 'week' ? 'selected' : '' %>>이번 주</option>
          <option value="month" <%= filters.period === 'month' ? 'selected' : '' %>>이번 달</option>
          <option value="90d" <%= filters.period === '90d' ? 'selected' : '' %>>최근 90일</option>
        </select>
      </div>
      <div class="filter-field">
        <label for="historyStatus">상태</label>
        <select id="historyStatus" name="status" onchange="this.form.submit()">
          <option value="DONE" <%= filters.status === 'DONE' ? 'selected' : '' %>>완료</option>
          <option value="ABORTED" <%= filters.status === 'ABORTED' ? 'selected' : '' %>>중단</option>
          <option value="ALL" <%= filters.status === 'ALL' ? 'selected' : '' %>>전체</option>
        </select>
      </div>
      <div class="filter-field">
        <label for="historySort">정렬</label>
        <select id="historySort" name="sort" onchange="this.form.submit()">
          <option value="latest" <%= filters.sort === 'latest' ? 'selected' : '' %>>최신순</option>
          <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>오래된순</option>
          <option value="score" <%= filters.sort === 'score' ? 'selected' : '' %>>점수 높은순</option>
        </select>
      </div>
    </form>
  </section>

  <section class="history-feed-section">
    <% if (safeSessions.length === 0) { %>
      <div class="card empty-state">
        <h3>조건에 맞는 기록이 없습니다</h3>
        <p class="muted">필터를 바꾸거나 새 운동을 시작해보세요.</p>
        <div class="empty-actions">
          <a class="primary" href="/workout/free">자율 운동 시작</a>
        </div>
      </div>
    <% } else { %>
      <div class="history-feed">
        <% safeSessions.forEach((session) => {
          const focus = toFocusPreview(session);
          const isRoutine = isRoutineItem(session);
          const itemTitle = isRoutine
            ? (session.routine_name || session.exercise?.name || '루틴 운동')
            : (session.exercise?.name || '운동');
        %>
          <article
            class="card history-item <%= String(session.status || '').toUpperCase() === 'ABORTED' ? 'is-aborted' : '' %> <%= isRoutine ? 'is-routine' : '' %>"
            data-session-id="<%= session.session_id %>"
            data-routine-instance-id="<%= session.routine_instance_id || '' %>"
            data-session-status="<%= String(session.status || '').toUpperCase() %>"
            data-session-score="<%= Math.max(0, Number(session.final_score) || 0) %>"
            data-item-type="<%= session.item_type || 'FREE_SESSION' %>"
          >
            <header class="history-item-header">
              <div class="history-item-date">
                <strong><%= new Date(session.started_at).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
                <span><%= new Date(session.started_at).toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit' }) %></span>
              </div>
              <div class="history-item-tags">
                <span class="history-tag mode"><%= modeLabelMap[session.mode] || session.mode || '-' %></span>
                <span class="history-tag status <%= String(session.status || '').toLowerCase() %>"><%= statusLabelMap[session.status] || session.status || '-' %></span>
                <span class="history-tag view"><%= viewLabelMap[session.selected_view] || session.selected_view || '-' %></span>
              </div>
            </header>

            <div class="history-item-body">
              <div class="history-item-main">
                <h3 class="history-item-title"><%= itemTitle %></h3>
                <div class="history-item-facts">
                  <% if (isRoutine) { %>
                    <div class="fact-chip">
                      <span>루틴 순서</span>
                      <strong><%= session.sequence_count || 0 %>개 운동</strong>
                    </div>
                  <% } else { %>
                    <div class="fact-chip">
                      <span>결과</span>
                      <strong><%= formatResultValue(session) %></strong>
                    </div>
                  <% } %>
                  <div class="fact-chip">
                    <span>운동 시간</span>
                    <strong><%= formatDuration(session.duration_sec) %></strong>
                  </div>
                  <div class="fact-chip">
                    <span><%= isRoutine ? '완료 세션' : '개선 1순위' %></span>
                    <strong><%= isRoutine ? `${session.done_sessions || 0}회` : focus.issue %></strong>
                  </div>
                </div>

                <p class="history-focus-headline">
                  <strong><%= isRoutine ? '루틴 구성' : '핵심 문제' %></strong>
                  <span><%= isRoutine ? `총 ${session.sequence_count || 0}개 운동 항목` : focus.headline %></span>
                </p>
                <p class="history-focus-action">
                  <strong>다음 행동</strong>
                  <span><%= isRoutine ? '상세에서 항목을 눌러 해당 운동 세션을 확인하세요.' : focus.action %></span>
                </p>
              </div>

              <div class="history-item-score">
                <div class="score-badge <%= scoreTier(session.final_score, session.status) %>">
                  <strong><%= String(session.status || '').toUpperCase() === 'ABORTED' ? '-' : Math.round(session.final_score || 0) %></strong>
                  <span>정확도</span>
                </div>
              </div>
            </div>

            <footer class="history-item-actions">
              <% if (isRoutine) { %>
                <button type="button" class="ghost small" onclick="viewRoutineDetail('<%= session.routine_instance_id %>')">루틴 상세</button>
              <% } else { %>
                <button type="button" class="ghost small" onclick="viewDetail('<%= session.session_id %>')">상세</button>
                <button type="button" class="danger small" onclick="deleteSession('<%= session.session_id %>')">삭제</button>
              <% } %>
            </footer>
          </article>
        <% }) %>
      </div>

      <% if (pagination.totalPages > 1) { %>
        <nav class="history-pagination" aria-label="페이지 이동">
          <% if (pagination.page > 1) { %>
            <a class="page-btn" href="?page=<%= pagination.page - 1 %>&exercise=<%= filters.exercise %>&period=<%= filters.period %>&status=<%= filters.status %>&sort=<%= filters.sort %>">이전</a>
          <% } %>
          <span class="page-info"><%= pagination.page %> / <%= pagination.totalPages %> · 총 <%= pagination.total %>건</span>
          <% if (pagination.page < pagination.totalPages) { %>
            <a class="page-btn" href="?page=<%= pagination.page + 1 %>&exercise=<%= filters.exercise %>&period=<%= filters.period %>&status=<%= filters.status %>&sort=<%= filters.sort %>">다음</a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </section>
</div>

<div class="modal" id="detailModal" hidden>
  <div class="modal-content history-detail-modal">
    <div class="modal-header">
      <h2 id="detailModalTitle">세션 상세</h2>
      <div class="modal-header-actions">
        <button
          type="button"
          id="detailModalBackBtn"
          class="detail-modal-back-btn"
          onclick="goDetailBack()"
          hidden
        >
          ← 뒤로가기
        </button>
        <button type="button" class="icon" onclick="closeModal()">✕</button>
      </div>
    </div>
    <div class="modal-body" id="detailModalBody">
      <div class="loading-state">불러오는 중...</div>
    </div>
  </div>
</div>

<script src="/js/history-page.js"></script>

  .rule-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .quest-template-item,
  .rule-item {
    background: var(--input-bg, #f8fafc);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
  }

  .quest-template-item.inactive,
  .rule-item.inactive {
    opacity: 0.7;
  }

  .quest-template-header,
  .rule-main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .quest-template-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .scope-badge,
  .type-badge,
  .category-badge,
  .difficulty-badge,
  .tier-range-badge,

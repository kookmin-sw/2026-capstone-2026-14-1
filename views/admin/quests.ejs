<%
const tierMap = {};
(tiers || []).forEach((tier) => {
  tierMap[tier.tier] = tier.name;
});

const scopeLabels = { DAILY: '일일', WEEKLY: '주간' };
const typeLabels = { DO: '수행', QUALITY: '품질', HABIT: '습관', CHALLENGE: '도전' };
const difficultyLabels = { EASY: '쉬움', NORMAL: '보통', HARD: '어려움' };

const scopes = (questScopes && questScopes.length > 0) ? questScopes : ['DAILY', 'WEEKLY'];
const types = (questTypes && questTypes.length > 0) ? questTypes : ['DO', 'QUALITY', 'HABIT', 'CHALLENGE'];
const difficulties = (questDifficulties && questDifficulties.length > 0) ? questDifficulties : ['EASY', 'NORMAL', 'HARD'];
const categories = (questCategories && questCategories.length > 0) ? questCategories : ['GENERAL', 'DO', 'QUALITY', 'HABIT', 'CHALLENGE'];

const tierText = (tier) => (tier === null || tier === undefined)
  ? null
  : `티어 ${tier}${tierMap[tier] ? ' - ' + tierMap[tier] : ''}`;

const tierRangeText = (minTier, maxTier) => {
  const minLabel = tierText(minTier);
  const maxLabel = tierText(maxTier);
  if (!minLabel && !maxLabel) return '전체 티어';
  if (minLabel && maxLabel) return `${minLabel} ~ ${maxLabel}`;
  if (minLabel) return `${minLabel} 이상`;
  return `${maxLabel} 이하`;
};
%>

<datalist id="quest-category-options">
  <% categories.forEach((category) => { %>
    <option value="<%= category %>"></option>
  <% }) %>
</datalist>

<div class="admin-header">
  <h1>퀘스트 관리</h1>
  <p class="admin-subtitle">퀘스트 템플릿과 슬롯 기반 선발 규칙을 함께 관리합니다.</p>
</div>

<!-- 퀘스트 템플릿 생성 -->
<div class="admin-card">
  <div class="admin-card-header">
    <h2 class="admin-card-title">새 퀘스트 템플릿</h2>
  </div>
  <form action="/admin/quests" method="POST" class="admin-form">
    <div class="form-row form-row-five">
      <div class="form-group">
        <label class="form-label">범위 *</label>
        <select name="scope" class="form-select" required>
          <% scopes.forEach((scope) => { %>
            <option value="<%= scope %>"><%= scopeLabels[scope] || scope %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">유형 *</label>
        <select name="type" class="form-select" required>
          <% types.forEach((type) => { %>
            <option value="<%= type %>"><%= typeLabels[type] || type %> (<%= type %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">카테고리 *</label>
        <input type="text" name="category" class="form-input" list="quest-category-options" value="GENERAL" required />
      </div>
      <div class="form-group">
        <label class="form-label">난이도 *</label>
        <select name="difficulty" class="form-select" required>
          <% difficulties.forEach((difficulty) => { %>
            <option value="<%= difficulty %>" <%= difficulty === 'NORMAL' ? 'selected' : '' %>><%= difficultyLabels[difficulty] || difficulty %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">보상 포인트 *</label>
        <input type="number" name="reward_points" class="form-input" value="100" min="0" required />
      </div>
    </div>

    <div class="form-row form-row-five">
      <div class="form-group">
        <label class="form-label">최소 티어</label>
        <select name="min_tier" class="form-select">
          <option value="">전체</option>
          <% (tiers || []).forEach((tier) => { %>
            <option value="<%= tier.tier %>">티어 <%= tier.tier %> - <%= tier.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">최대 티어</label>
        <select name="max_tier" class="form-select">
          <option value="">전체</option>
          <% (tiers || []).forEach((tier) => { %>
            <option value="<%= tier.tier %>">티어 <%= tier.tier %> - <%= tier.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">선발 가중치 *</label>
        <input type="number" name="selection_weight" class="form-input" value="100" min="1" required />
      </div>
      <div class="form-group">
        <label class="form-label">쿨다운(일) *</label>
        <input type="number" name="cooldown_days" class="form-input" value="0" min="0" required />
      </div>
      <div class="form-group">
        <label class="form-label">배타 그룹</label>
        <input type="text" name="exclusive_group" class="form-input" placeholder="예: DAILY_HARD_LIMIT" />
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">제목 *</label>
      <input type="text" name="title" class="form-input" placeholder="오늘 운동 3회 완료하기" required />
    </div>
    <div class="form-group">
      <label class="form-label">조건 (JSON)</label>
      <textarea name="condition" class="form-textarea" rows="3" placeholder='{"metric":"workout_count","target":3}'></textarea>
      <div class="form-hint">예시 metric: workout_count, exercise_code, total_reps, duration_min, sets, score_above, avg_score, weekly_days</div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="toggle">
          <input type="checkbox" name="is_active" checked />
          <span class="toggle-slider"></span>
        </label>
        <span class="toggle-label">활성화</span>
      </div>
    </div>
    <button type="submit" class="btn primary">퀘스트 템플릿 추가</button>
  </form>
</div>

<!-- 퀘스트 템플릿 목록 -->
<div class="admin-card">
  <div class="admin-card-header">
    <h2 class="admin-card-title">퀘스트 템플릿 목록</h2>
    <span class="badge"><%= templates.length %>개</span>
  </div>

  <% if (templates.length === 0) { %>
    <p class="empty-message">등록된 퀘스트 템플릿이 없습니다.</p>
  <% } else { %>
    <div class="quest-template-list">
      <% templates.forEach((template) => { %>
        <div class="quest-template-item <%= !template.is_active ? 'inactive' : '' %>">
          <div class="quest-template-header">
            <div class="quest-template-badges">
              <span class="scope-badge <%= String(template.scope || '').toLowerCase() %>"><%= scopeLabels[template.scope] || template.scope %></span>
              <span class="type-badge <%= String(template.type || '').toLowerCase() %>"><%= typeLabels[template.type] || template.type %></span>
              <span class="category-badge"><%= template.category %></span>
              <span class="difficulty-badge <%= String(template.difficulty || '').toLowerCase() %>"><%= difficultyLabels[template.difficulty] || template.difficulty %></span>
              <span class="tier-range-badge <%= (template.min_tier === null && template.max_tier === null) ? 'all' : '' %>"><%= tierRangeText(template.min_tier, template.max_tier) %></span>
              <% if (!template.is_active) { %>
                <span class="inactive-badge">비활성</span>
              <% } %>
            </div>
            <span class="reward-points">+<%= template.reward_points %>P</span>
          </div>

          <h3 class="quest-template-title"><%= template.title %></h3>

          <div class="meta-grid">
            <div><strong>가중치:</strong> <%= template.selection_weight %></div>
            <div><strong>쿨다운:</strong> <%= template.cooldown_days %>일</div>
            <div><strong>배타 그룹:</strong> <%= template.exclusive_group || '-' %></div>
          </div>

          <div class="quest-template-condition">
            <code><%= JSON.stringify(template.condition || {}) %></code>
          </div>

          <div class="quest-template-actions">
            <button type="button" class="btn ghost small" onclick="editQuest('<%= template.quest_template_id %>')">수정</button>
            <form action="/admin/quests/<%= template.quest_template_id %>/delete" method="POST" style="display: inline;">
              <button type="submit" class="btn danger small" onclick="return confirm('정말 삭제하시겠습니까?')">삭제</button>
            </form>
          </div>

          <form id="edit-form-<%= template.quest_template_id %>" class="edit-form hidden" action="/admin/quests/<%= template.quest_template_id %>" method="POST">
            <div class="form-row form-row-five">
              <div class="form-group">
                <label class="form-label">범위</label>
                <select name="scope" class="form-select">
                  <% scopes.forEach((scope) => { %>
                    <option value="<%= scope %>" <%= template.scope === scope ? 'selected' : '' %>><%= scopeLabels[scope] || scope %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">유형</label>
                <select name="type" class="form-select">
                  <% types.forEach((type) => { %>
                    <option value="<%= type %>" <%= template.type === type ? 'selected' : '' %>><%= typeLabels[type] || type %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">카테고리</label>
                <input type="text" name="category" class="form-input" list="quest-category-options" value="<%= template.category %>" />
              </div>
              <div class="form-group">
                <label class="form-label">난이도</label>
                <select name="difficulty" class="form-select">
                  <% difficulties.forEach((difficulty) => { %>
                    <option value="<%= difficulty %>" <%= template.difficulty === difficulty ? 'selected' : '' %>><%= difficultyLabels[difficulty] || difficulty %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">보상</label>
                <input type="number" name="reward_points" class="form-input" value="<%= template.reward_points %>" min="0" />
              </div>
            </div>

            <div class="form-row form-row-five">
              <div class="form-group">
                <label class="form-label">최소 티어</label>
                <select name="min_tier" class="form-select">
                  <option value="" <%= template.min_tier === null || template.min_tier === undefined ? 'selected' : '' %>>전체</option>
                  <% (tiers || []).forEach((tier) => { %>
                    <option value="<%= tier.tier %>" <%= template.min_tier === tier.tier ? 'selected' : '' %>>티어 <%= tier.tier %> - <%= tier.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">최대 티어</label>
                <select name="max_tier" class="form-select">
                  <option value="" <%= template.max_tier === null || template.max_tier === undefined ? 'selected' : '' %>>전체</option>
                  <% (tiers || []).forEach((tier) => { %>
                    <option value="<%= tier.tier %>" <%= template.max_tier === tier.tier ? 'selected' : '' %>>티어 <%= tier.tier %> - <%= tier.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">선발 가중치</label>
                <input type="number" name="selection_weight" class="form-input" value="<%= template.selection_weight %>" min="1" />
              </div>
              <div class="form-group">
                <label class="form-label">쿨다운(일)</label>
                <input type="number" name="cooldown_days" class="form-input" value="<%= template.cooldown_days %>" min="0" />
              </div>
              <div class="form-group">
                <label class="form-label">배타 그룹</label>
                <input type="text" name="exclusive_group" class="form-input" value="<%= template.exclusive_group || '' %>" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">제목</label>
              <input type="text" name="title" class="form-input" value="<%= template.title %>" />
            </div>
            <div class="form-group">
              <label class="form-label">조건 (JSON)</label>
              <textarea name="condition" class="form-textarea" rows="2"><%= JSON.stringify(template.condition || {}) %></textarea>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="toggle">
                  <input type="checkbox" name="is_active" <%= template.is_active ? 'checked' : '' %> />
                  <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">활성</span>
              </div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn primary small">저장</button>
              <button type="button" class="btn ghost small" onclick="cancelEdit('<%= template.quest_template_id %>')">취소</button>
            </div>
          </form>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>


<!-- 슬롯 규칙 목록 -->
<div class="admin-card">
  <div class="admin-card-header">
    <h2 class="admin-card-title">슬롯 선발 규칙 목록</h2>
    <span class="badge"><%= assignmentRules.length %>개</span>
  </div>

  <% if (assignmentRules.length === 0) { %>
    <p class="empty-message">등록된 슬롯 선발 규칙이 없습니다.</p>
  <% } else { %>
    <div class="rule-list">
      <% assignmentRules.forEach((rule) => { %>
        <div class="rule-item <%= !rule.is_active ? 'inactive' : '' %>">
          <div class="rule-main">
            <div class="quest-template-badges">
              <span class="scope-badge <%= String(rule.scope || '').toLowerCase() %>"><%= scopeLabels[rule.scope] || rule.scope %></span>
              <span class="slot-badge">Slot <%= rule.slot_no %></span>
              <span class="type-badge <%= String(rule.type || '').toLowerCase() %>"><%= typeLabels[rule.type] || rule.type %></span>
              <span class="category-badge"><%= rule.category %></span>
              <span class="tier-range-badge <%= (rule.min_tier === null && rule.max_tier === null) ? 'all' : '' %>"><%= tierRangeText(rule.min_tier, rule.max_tier) %></span>
              <% if (!rule.is_active) { %>
                <span class="inactive-badge">비활성</span>
              <% } %>
            </div>
            <div class="rule-count">선발 <strong><%= rule.count %>개</strong></div>
          </div>
          <div class="quest-template-actions">
            <button type="button" class="btn ghost small" onclick="editRule('<%= rule.rule_id %>')">수정</button>
            <form action="/admin/quests/rules/<%= rule.rule_id %>/delete" method="POST" style="display:inline;">
              <button type="submit" class="btn danger small" onclick="return confirm('정말 삭제하시겠습니까?')">삭제</button>
            </form>
          </div>

          <form id="rule-edit-form-<%= rule.rule_id %>" class="edit-form hidden" action="/admin/quests/rules/<%= rule.rule_id %>" method="POST">
            <div class="form-row form-row-six">
              <div class="form-group">
                <label class="form-label">범위</label>
                <select name="scope" class="form-select">
                  <% scopes.forEach((scope) => { %>
                    <option value="<%= scope %>" <%= rule.scope === scope ? 'selected' : '' %>><%= scopeLabels[scope] || scope %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">슬롯 번호</label>
                <input type="number" name="slot_no" class="form-input" min="1" value="<%= rule.slot_no %>" />
              </div>
              <div class="form-group">
                <label class="form-label">카테고리</label>
                <input type="text" name="category" class="form-input" list="quest-category-options" value="<%= rule.category %>" />
              </div>
              <div class="form-group">
                <label class="form-label">유형</label>
                <select name="type" class="form-select">
                  <% types.forEach((type) => { %>
                    <option value="<%= type %>" <%= rule.type === type ? 'selected' : '' %>><%= typeLabels[type] || type %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">선발 개수</label>
                <input type="number" name="count" class="form-input" min="1" value="<%= rule.count %>" />
              </div>
              <div class="form-group">
                <label class="form-label">활성</label>
                <label class="toggle">
                  <input type="checkbox" name="is_active" <%= rule.is_active ? 'checked' : '' %> />
                  <span class="toggle-slider"></span>
                </label>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">최소 티어</label>
                <select name="min_tier" class="form-select">
                  <option value="" <%= rule.min_tier === null || rule.min_tier === undefined ? 'selected' : '' %>>전체</option>
                  <% (tiers || []).forEach((tier) => { %>
                    <option value="<%= tier.tier %>" <%= rule.min_tier === tier.tier ? 'selected' : '' %>>티어 <%= tier.tier %> - <%= tier.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">최대 티어</label>
                <select name="max_tier" class="form-select">
                  <option value="" <%= rule.max_tier === null || rule.max_tier === undefined ? 'selected' : '' %>>전체</option>
                  <% (tiers || []).forEach((tier) => { %>
                    <option value="<%= tier.tier %>" <%= rule.max_tier === tier.tier ? 'selected' : '' %>>티어 <%= tier.tier %> - <%= tier.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn primary small">저장</button>
              <button type="button" class="btn ghost small" onclick="cancelRuleEdit('<%= rule.rule_id %>')">취소</button>
            </div>
          </form>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<style>

<script id="attendanceActivityDaysData" type="application/json"><%- JSON.stringify(safeActivityDays).replace(/</g, '\\u003c') %></script>
<script>
  (function initAttendanceHeatmapRangeSelector() {
    const rangeSelect = document.getElementById('attendanceRangeSelect');
    const periodLabel = document.getElementById('attendancePeriodLabel');
    const heatmapMain = document.getElementById('attendanceHeatmapMain');
    const monthLabelsEl = document.getElementById('attendanceMonthLabels');
    const heatmapGridEl = document.getElementById('attendanceHeatmapGrid');
    const rawDataEl = document.getElementById('attendanceActivityDaysData');
    const shellEl = heatmapMain ? heatmapMain.closest('.attendance-heatmap-shell') : null;
    const weekdayLabelsEl = shellEl ? shellEl.querySelector('.attendance-weekday-labels') : null;
    if (!rangeSelect || !periodLabel || !heatmapMain || !monthLabelsEl || !heatmapGridEl || !rawDataEl) return;

    const AUTO_PERIOD_KEY = 'auto';
    const FIXED_PERIOD_DAYS = {
      '1m': 30,
      '3m': 90,
      '6m': 180,
      '1y': 365
    };

    const FIXED_PERIOD_LABEL = {
      '1m': '최근 1달 출석 히트맵',
      '3m': '최근 3달 출석 히트맵',
      '6m': '최근 6달 출석 히트맵',
      '1y': '최근 1년 출석 히트맵'
    };

    const toSafeNumber = (value, fallback = 0) => {
      const parsed = Number(value);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const parseCssPixels = (value, fallback = 0) => {
      const parsed = parseFloat(value);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const clampLevel = (value) => Math.max(0, Math.min(4, Math.round(toSafeNumber(value, 0))));

    const escapeAttr = (value) => String(value)
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

    const normalizeDate = (value) => {
      const date = new Date(value);
      date.setHours(0, 0, 0, 0);
      return date;
    };

    const setAutoOptionLabel = (dayCount) => {
      const autoOption = rangeSelect.querySelector('option[value="auto"]');
      if (!autoOption) return;
      autoOption.textContent = `자동 (최근 ${dayCount}일)`;
    };

    const computeAutoWindowDays = () => {
      if (!shellEl) return 365;

      const shellStyles = getComputedStyle(shellEl);
      const shellWidth = shellEl.clientWidth || shellEl.getBoundingClientRect().width;
      const paddingX = parseCssPixels(shellStyles.paddingLeft, 0) + parseCssPixels(shellStyles.paddingRight, 0);
      const shellGap = parseCssPixels(shellStyles.columnGap || shellStyles.gap, 0);
      const weekdayWidth = weekdayLabelsEl
        ? (weekdayLabelsEl.clientWidth || weekdayLabelsEl.getBoundingClientRect().width)
        : 0;

      const availableGridWidth = Math.max(140, shellWidth - paddingX - shellGap - weekdayWidth);
      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      const targetCellSize = isMobile ? 11 : 14;
      const targetCellGap = isMobile ? 3 : 4;
      const weekCount = Math.max(4, Math.floor((availableGridWidth + targetCellGap) / (targetCellSize + targetCellGap)));
      return Math.max(28, Math.min(365, weekCount * 7));
    };

    let allDays = [];
    try {
      allDays = JSON.parse(rawDataEl.textContent || '[]');
    } catch (error) {
      console.error('Attendance heatmap data parse error:', error);
      return;
    }

    allDays = allDays
      .map((day) => {
        if (!day || !day.date) return null;
        const date = normalizeDate(`${day.date}T00:00:00`);
        if (Number.isNaN(date.getTime())) return null;
        return { ...day, _date: date };
      })
      .filter(Boolean)
      .sort((a, b) => a._date.getTime() - b._date.getTime());

    if (!allDays.length) return;

    const buildVisibleDays = (periodKey, autoWindowDays) => {
      const windowSize = periodKey === AUTO_PERIOD_KEY
        ? autoWindowDays
        : (FIXED_PERIOD_DAYS[periodKey] || FIXED_PERIOD_DAYS['1y']);
      const endDate = normalizeDate(allDays[allDays.length - 1]._date);
      const startDate = new Date(endDate);
      startDate.setDate(startDate.getDate() - (windowSize - 1));

      const alignedStart = new Date(startDate);
      alignedStart.setDate(alignedStart.getDate() - alignedStart.getDay());
      alignedStart.setHours(0, 0, 0, 0);

      return allDays.filter((day) => day._date >= alignedStart && day._date <= endDate);
    };

    const buildMonthMarkers = (days) => {
      const markers = [];
      const seen = new Set();
      days.forEach((day, index) => {
        const month = day._date.getMonth() + 1;
        const markerKey = `${day._date.getFullYear()}-${month}`;
        const shouldRender = index === 0 || day._date.getDate() === 1;
        if (!shouldRender || seen.has(markerKey)) return;
        markers.push({
          label: `${month}월`,
          column: Math.floor(index / 7) + 1
        });
        seen.add(markerKey);
      });
      return markers;
    };

    const renderHeatmap = (periodKey) => {
      const autoWindowDays = computeAutoWindowDays();
      setAutoOptionLabel(autoWindowDays);

      const visibleDays = buildVisibleDays(periodKey, autoWindowDays);
      const weekCount = Math.max(1, Math.ceil(visibleDays.length / 7));
      heatmapMain.style.setProperty('--attendance-week-count', String(weekCount));
      periodLabel.textContent = periodKey === AUTO_PERIOD_KEY
        ? `최근 ${autoWindowDays}일 출석 히트맵`
        : (FIXED_PERIOD_LABEL[periodKey] || FIXED_PERIOD_LABEL['1y']);

      const monthMarkersInPeriod = buildMonthMarkers(visibleDays);
      monthLabelsEl.innerHTML = monthMarkersInPeriod
        .map((marker) => `<span style="grid-column: ${marker.column};">${escapeAttr(marker.label)}</span>`)
        .join('');

      heatmapGridEl.innerHTML = visibleDays
        .map((day) => {
          const workoutCount = Math.max(0, Math.round(toSafeNumber(day.workoutCount, 0)));
          const level = clampLevel(Number.isFinite(Number(day.level)) ? day.level : (day.hasWorkout ? 1 : 0));
          const title = workoutCount > 0
            ? `${day.date} · ${workoutCount}회 운동`
            : `${day.date} · 기록 없음`;
          return `<div class="attendance-cell level-${level}" title="${escapeAttr(title)}"></div>`;
        })
        .join('');
    };

    let currentPeriod = rangeSelect.querySelector('option[value="auto"]') ? 'auto' : '1y';
    rangeSelect.value = currentPeriod;
    renderHeatmap(currentPeriod);

    rangeSelect.addEventListener('change', () => {
      currentPeriod = rangeSelect.value;
      renderHeatmap(currentPeriod);
    });

    let rerenderRaf = null;
    const scheduleAutoRerender = () => {
      if (currentPeriod !== AUTO_PERIOD_KEY) return;
      if (rerenderRaf != null) {
        window.cancelAnimationFrame(rerenderRaf);
      }
      rerenderRaf = window.requestAnimationFrame(() => {
        rerenderRaf = null;
        renderHeatmap(AUTO_PERIOD_KEY);
      });
    };

    window.addEventListener('resize', scheduleAutoRerender);

    if (typeof ResizeObserver !== 'undefined' && shellEl) {
      const shellResizeObserver = new ResizeObserver(() => {
        scheduleAutoRerender();
      });
      shellResizeObserver.observe(shellEl);
    } else if (shellEl) {
      window.addEventListener('orientationchange', () => {
        scheduleAutoRerender();
      });
    }

    if (currentPeriod === AUTO_PERIOD_KEY) {
      renderHeatmap(currentPeriod);
    }
  })();
</script>

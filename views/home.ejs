<%
  const safeToday = today || '';
  const safeTodaySummary = todaySummary || { count: 0, totalMinutes: 0, totalReps: 0, totalDurationResultSec: 0, avgScore: 0 };
  const safeWeekSummary = weekSummary || { count: 0, totalMinutes: 0, totalReps: 0, totalDurationResultSec: 0, avgScore: 0 };
  const safeActivityDays = Array.isArray(activityDays) ? activityDays : [];
  const safeDailyQuests = Array.isArray(dailyQuests) ? dailyQuests : [];
  const safeWeeklyQuests = Array.isArray(weeklyQuests) ? weeklyQuests : [];

  const dailyDoneCount = safeDailyQuests.filter((quest) => quest.status === 'DONE').length;
  const dailyTotalCount = safeDailyQuests.length;
  const dailyProgressRate = dailyTotalCount > 0 ? Math.round((dailyDoneCount / dailyTotalCount) * 100) : 0;

  const weeklyDoneCount = safeWeeklyQuests.filter((quest) => quest.status === 'DONE').length;
  const weeklyTotalCount = safeWeeklyQuests.length;
  const weeklyProgressRate = weeklyTotalCount > 0 ? Math.round((weeklyDoneCount / weeklyTotalCount) * 100) : 0;

  const weekDayLabels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
  const activityWeeks = [];
  for (let index = 0; index < safeActivityDays.length; index += 7) {
    activityWeeks.push(safeActivityDays.slice(index, index + 7));
  }

  const monthMarkers = [];
  const monthMarkerKeys = new Set();
  safeActivityDays.forEach((day, index) => {
    if (!day || !day.date) return;
    const parsedDate = new Date(`${day.date}T00:00:00`);
    if (Number.isNaN(parsedDate.getTime())) return;

    const month = parsedDate.getMonth() + 1;
    const monthKey = `${parsedDate.getFullYear()}-${month}`;
    const isFirstCell = index === 0;
    const isFirstDayOfMonth = parsedDate.getDate() === 1;
    if (!isFirstCell && !isFirstDayOfMonth) return;
    if (monthMarkerKeys.has(monthKey)) return;

    monthMarkers.push({
      label: `${month}월`,
      column: Math.floor(index / 7) + 1
    });
    monthMarkerKeys.add(monthKey);
  });
%>

<div class="page active home-v2-page">
  <section class="page-header">
    <div>
      <h1>반갑습니다, <%= typeof user !== 'undefined' && user ? user.nickname : '게스트' %>님</h1>
      <p class="date"><%= safeToday %></p>
    </div>
  </section>

  <div class="grid three home-summary-grid">
    <div class="card hero home-summary-card">
      <span class="summary-label">연속 운동</span>
      <strong class="summary-value"><%= streak || 0 %>일</strong>
      <span class="summary-meta">꾸준함이 실력을 만듭니다</span>
    </div>
    <div class="card home-summary-card">
      <span class="summary-label">오늘</span>
      <strong class="summary-value"><%= safeTodaySummary.count %>회</strong>
      <span class="summary-meta"><%= safeTodaySummary.totalMinutes %>분 · <%= safeTodaySummary.totalReps %>회 · <%= safeTodaySummary.totalDurationResultSec %>초</span>
    </div>
    <div class="card home-summary-card">
      <span class="summary-label">이번 주</span>
      <strong class="summary-value"><%= safeWeekSummary.count %>회</strong>
      <span class="summary-meta"><%= safeWeekSummary.totalMinutes %>분 · 평균 <%= safeWeekSummary.avgScore %>점</span>
    </div>
  </div>

  <div class="grid two home-quest-grid">
    <div class="card">
      <div class="card-header">
        <h3>일일 퀘스트</h3>
        <a href="/quest" class="ghost" style="font-size: 12px;">전체보기</a>
      </div>
      <ul class="quest-list">
        <% if (safeDailyQuests.length > 0) { %>
          <% safeDailyQuests.slice(0, 3).forEach((quest) => { %>
            <li class="<%= quest.status === 'DONE' ? 'completed' : '' %>">
              <span><%= quest.title %></span>
              <% if (quest.status === 'DONE') { %>
                <span class="muted">완료</span>
              <% } else { %>
                <span class="muted"><%= quest.progress %>/<%= quest.target %><%= quest.progressUnit || '' %></span>
              <% } %>
            </li>
          <% }) %>
        <% } else { %>
          <li class="empty"><span class="muted">일일 퀘스트가 없습니다</span></li>
        <% } %>
      </ul>
      <div class="quest">
        <div class="progress">
          <div class="progress-bar" style="width: <%= dailyProgressRate %>%"></div>
        </div>
        <span class="quest-progress">일일 퀘스트 <%= dailyDoneCount %>/<%= dailyTotalCount %> 완료</span>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3>주간 퀘스트</h3>
        <a href="/quest" class="ghost" style="font-size: 12px;">전체보기</a>
      </div>
      <ul class="quest-list">
        <% if (safeWeeklyQuests.length > 0) { %>
          <% safeWeeklyQuests.slice(0, 3).forEach((quest) => { %>
            <li class="<%= quest.status === 'DONE' ? 'completed' : '' %>">
              <span><%= quest.title %></span>
              <% if (quest.status === 'DONE') { %>
                <span class="muted">완료</span>
              <% } else { %>
                <span class="muted"><%= quest.progress %>/<%= quest.target %><%= quest.progressUnit || '' %></span>
              <% } %>
            </li>
          <% }) %>
        <% } else { %>
          <li class="empty"><span class="muted">주간 퀘스트가 없습니다</span></li>
        <% } %>
      </ul>
      <div class="quest">
        <div class="progress">
          <div class="progress-bar" style="width: <%= weeklyProgressRate %>%"></div>
        </div>
        <span class="quest-progress">주간 퀘스트 <%= weeklyDoneCount %>/<%= weeklyTotalCount %> 완료</span>
      </div>
    </div>
  </div>

  <div class="card home-attendance-card">
    <div class="attendance-header">
      <div class="attendance-header-copy">
        <span class="attendance-kicker">WORKOUT STREAK</span>
        <h3>현재 <%= streak || 0 %>일</h3>
        <p class="muted attendance-period-label" id="attendancePeriodLabel">연속 운동 일 수</p>
      </div>
    </div>

    <div class="attendance-heatmap-shell">
      <div class="attendance-weekday-labels">
        <% weekDayLabels.forEach((label) => { %>
          <span><%= label %></span>
        <% }) %>
      </div>

      <div
        class="attendance-heatmap-main"
        id="attendanceHeatmapMain"
        style="--attendance-week-count: <%= Math.max(1, activityWeeks.length) %>;"
      >
        <div class="attendance-month-labels" id="attendanceMonthLabels">
          <% monthMarkers.forEach((marker) => { %>
            <span style="grid-column: <%= marker.column %>;"><%= marker.label %></span>
          <% }) %>
        </div>

        <div class="attendance-heatmap-grid" id="attendanceHeatmapGrid">
          <% safeActivityDays.forEach((day) => { %>
            <% const workoutCount = Number(day.workoutCount || 0); %>
            <% const rawLevel = Number.isFinite(day.level) ? day.level : (day.hasWorkout ? 1 : 0); %>
            <% const cellLevel = Math.max(0, Math.min(4, rawLevel)); %>
            <% const cellTitle = workoutCount > 0 ? `${day.date} · ${workoutCount}회 운동` : `${day.date} · 기록 없음`; %>
            <div class="attendance-cell level-<%= cellLevel %>" title="<%= cellTitle %>"></div>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="attendance-legend">
      <span class="legend-label">적음</span>
      <span class="attendance-cell level-0 legend-cell"></span>
      <span class="attendance-cell level-1 legend-cell"></span>
      <span class="attendance-cell level-2 legend-cell"></span>
      <span class="attendance-cell level-3 legend-cell"></span>
      <span class="attendance-cell level-4 legend-cell"></span>
      <span class="legend-label">많음</span>
      <span class="legend-scale">1 / 2-3 / 4-5 / 6+</span>
    </div>
  </div>
</div>


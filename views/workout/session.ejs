<%
  const isRoutineMode = mode === 'ROUTINE';
  const isLearnMode = mode === 'LEARN';
  const currentExercise = exercise;
  const isPlankExercise = String(currentExercise?.code || '').trim().toLowerCase() === 'plank';
  const allowedViews = Array.isArray(currentExercise?.allowed_views) && currentExercise.allowed_views.length > 0
    ? currentExercise.allowed_views
    : ['FRONT'];
  const defaultView = currentExercise?.default_view && allowedViews.includes(currentExercise.default_view)
    ? currentExercise.default_view
    : allowedViews[0];
  const viewLabels = {
    FRONT: '정면',
    SIDE: '측면',
    DIAGONAL: '대각선'
  };
  const normalizeScriptName = (value) => String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9_-]/g, '')
    .replace(/_/g, '-');
  const resolveExerciseModuleScriptName = (value) => {
    const normalized = normalizeScriptName(value);
    if (!normalized) return null;
    if (normalized === 'pushup' || normalized === 'push-up') {
      return 'push-up-exercise.js';
    }
    return `${normalized}-exercise.js`;
  };
  const fallbackModuleScripts = [];
  const firstScript = resolveExerciseModuleScriptName(currentExercise?.code);
  if (firstScript) fallbackModuleScripts.push(firstScript);
  if (isRoutineMode && routine?.routine_setup) {
    routine.routine_setup.forEach((step) => {
      const filename = resolveExerciseModuleScriptName(step?.exercise?.code);
      if (!filename) return;
      if (!fallbackModuleScripts.includes(filename)) {
        fallbackModuleScripts.push(filename);
      }
    });
  }
  const moduleScripts = Array.isArray(exerciseModuleScripts) && exerciseModuleScripts.length > 0
    ? exerciseModuleScripts
    : (exerciseModuleScript ? [exerciseModuleScript] : fallbackModuleScripts);
%>

  <!-- MediaPipe Pose CDN -->
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/pose/pose.js" crossorigin="anonymous"></script>

  <!-- FitPlus AI 모듈 (순서 유지) -->
  <script src="/js/workout/one-euro-filter.js"></script>
  <script src="/js/workout/exercise-registry.js"></script>
  <% moduleScripts.forEach((scriptName) => { %>
    <script src="/js/workout/exercises/<%= scriptName %>"></script>
  <% }) %>
  <script src="/js/workout/pose-engine.js"></script>
  <script src="/js/workout/scoring-engine.js"></script>
  <script src="/js/workout/rep-counter.js"></script>
  <script src="/js/workout/session-buffer.js"></script>
  <script src="/js/workout/session-camera.js"></script>
  <script src="/js/workout/quality-gate-session.js"></script>
  <script src="/js/workout/session-ui.js"></script>
  <script src="/js/workout/session-voice.js"></script>
  <script src="/js/workout/routine-session-manager.js"></script>
  <script src="/js/workout/onboarding-guide.js"></script>
  <script src="/js/workout/learn-step-engine.js"></script>
  <script src="/js/workout/session-controller.js"></script>

  <div class="workout-container">
    <!-- 상단 헤더 -->
    <header class="workout-header">
      <div class="workout-title">
        <% if (isRoutineMode && routine) { %>
          <h2>
            <%= routine.name %>
          </h2>
          <span class="muted">루틴 운동</span>
          <% } else if (isLearnMode) { %>
            <h2>
              <%= currentExercise.name %>
            </h2>
            <span class="muted">운동 배우기</span>
          <% } else { %>
            <h2>
              <%= currentExercise.name %>
            </h2>
            <span class="muted">자율 운동</span>
            <% } %>
      </div>

      <!-- 상태 표시 -->
      <div class="status-badges">
        <span class="status preparing" id="statusBadge">준비 중</span>
      </div>

      <div class="workout-actions">
        <button class="ghost" onclick="confirmExit()">X 종료</button>
      </div>
    </header>

    <!-- 알림 영역 -->
    <div class="alert-container" id="alertContainer" hidden>
      <div class="alert">
        <strong id="alertTitle">자세 알림</strong>
        <span id="alertMessage">무릎 각도를 더 굽혀주세요</span>
      </div>
    </div>

    <div class="workout-main">
      <!-- 카메라 영역 -->
      <div class="camera-section">
        <div class="camera-frame" id="cameraFrame">
          <video id="videoElement" autoplay playsinline></video>
          <canvas id="poseCanvas"></canvas>
          <div class="camera-overlay" id="cameraOverlay">
            <p>카메라를 연결 중...</p>
          </div>
        </div>

        <!-- 셋업 컨트롤 컨테이너 (운동 시작 시 숨김) -->
        <div class="setup-panel-container" id="setupPanelContainer">
          <!-- 입력 소스 선택 (준비 단계) -->
          <div class="source-select" id="sourceSelect" role="group" aria-label="카메라 입력 소스">
            <span class="source-select-label muted">입력 소스</span>
            <div class="source-select-buttons">
              <button type="button" class="ghost source-btn active" data-source="webcam">웹캠</button>
              <button type="button" class="ghost source-btn" data-source="screen">화면 공유</button>
              <button type="button" class="ghost source-btn" data-source="mobile_rear">휴대폰 카메라</button>
            </div>
            <p class="source-select-hint muted">휴대폰은 브라우저에서 후면 카메라를 사용합니다. PC에서는 웹캠 또는 화면 공유를 선택하세요.</p>
          </div>

          <div class="camera-privacy-notice" aria-label="카메라 및 개인정보 안내">
            <strong>카메라 안내</strong>
            <p>영상 원본은 서버에 저장하지 않습니다. 브라우저에서 자세를 분석하고, 서버에는 세션 결과와 점수 요약, 메트릭 집계, 이벤트 기록만 저장됩니다.</p>
            <p>FitPlus는 운동 보조 서비스이며 의료 진단이나 치료 목적의 서비스가 아닙니다.</p>
          </div>

          <div class="source-select" id="viewSelect" role="group" aria-label="채점 자세 선택">
            <span class="source-select-label muted">채점 자세</span>
            <div class="source-select-buttons">
              <% allowedViews.forEach((viewCode) => { %>
                <button
                  type="button"
                  class="ghost source-btn <%= viewCode === defaultView ? 'active' : '' %>"
                  data-view="<%= viewCode %>">
                  <%= viewLabels[viewCode] || viewCode %>
                </button>
              <% }) %>
            </div>
            <p class="source-select-hint muted">운동 시작 전에 허용된 자세 중 하나를 선택하세요. 선택한 자세가 세션 기록과 채점 로직에 함께 반영됩니다.</p>
          </div>

          <div class="source-select" id="voiceFeedbackSelect" role="group" aria-label="음성 피드백 설정">
            <span class="source-select-label muted" id="voiceFeedbackStatus">음성 피드백 켜짐</span>
            <div class="source-select-buttons">
              <button
                type="button"
                class="ghost source-btn active"
                id="voiceFeedbackToggle"
                data-voice-feedback-toggle="true">
                켜짐
              </button>
            </div>
            <p class="source-select-hint muted" id="voiceFeedbackHint">운동 중 주요 피드백을 음성으로 안내합니다.</p>
          </div>

          <div class="source-select" id="plankTargetSelect" role="group" aria-label="플랭크 목표 시간 선택" data-plank-target-ui <%= isPlankExercise ? '' : 'hidden' %>>
              <span class="source-select-label muted">목표 시간</span>
              <div class="source-select-buttons" style="flex-wrap: wrap;">
                <button type="button" class="ghost source-btn active" data-plank-target-sec="15">15초</button>
                <button type="button" class="ghost source-btn" data-plank-target-sec="30">30초</button>
                <button type="button" class="ghost source-btn" data-plank-target-sec="45">45초</button>
                <button type="button" class="ghost source-btn" data-plank-target-sec="60">60초</button>
                <button type="button" class="ghost source-btn" data-plank-target-sec="90">90초</button>
              </div>
              <div class="plank-target-custom" style="margin-top: 14px; display: grid; gap: 8px;">
                <label for="plankTargetSeconds" class="muted" style="font-size: 13px;">직접 입력</label>
                <div style="display: flex; gap: 8px; align-items: center;">
                  <input
                    id="plankTargetSeconds"
                    name="plank_target_seconds"
                    type="number"
                    min="10"
                    step="1"
                    value="30"
                    class="form-input"
                    style="max-width: 160px;"
                    inputmode="numeric"
                  />
                  <span class="muted">초</span>
                </div>
                <p class="source-select-hint muted" id="plankTargetHint">플랭크는 목표 시간을 먼저 정한 뒤 시작합니다. 목표 시간은 세션 종료 시 점수 정규화 기준이 됩니다.</p>
              </div>
          </div>

          <!-- 카메라 컨트롤 -->
          <div class="camera-actions" id="cameraActions">
            <button class="primary" id="startBtn" onclick="startWorkout()" disabled>
              운동 시작
            </button>
          </div>
        </div>
      </div>

      <!-- 사이드 패널 -->
      <aside class="workout-sidebar">
        <!-- 실시간 점수 -->
        <div class="card score-card">
          <div class="score-header">
            <span class="muted" id="scoreModeLabel"><%= isLearnMode ? '현재 step 진행률' : (isPlankExercise ? '현재 자세 상태' : '이번 rep 상태') %></span>
            <!-- <span class="muted" id="phaseInfo" style="font-size: 12px;"></span> -->
          </div>
          <!-- <div class="score-header">
            <span class="muted"></span>
            <span class="muted" id="viewInfo" style="font-size: 11px;"></span>
          </div> -->
          <div class="score" id="liveScore">--</div>
          <div class="score-detail" id="scoreBreakdown">
            <!-- 점수 세부항목이 여기에 표시됨 -->
          </div>
        </div>

        <div class="card learn-card" id="learnCard" <%= isLearnMode ? '' : 'hidden' %>>
          <div class="card-header">
            <div>
              <span class="muted" id="learnStepCounter">Step 1 / 1</span>
              <h3 id="learnStepTitle">운동 배우기 준비</h3>
            </div>
            <span class="badge" id="learnStepBadge">자세 맞추기</span>
          </div>
          <p class="muted learn-step-instruction" id="learnStepInstruction">카메라를 연결하고 학습을 시작하세요.</p>
          <div class="progress learn-step-progress">
            <div class="progress-bar" id="learnHoldProgressBar" style="width: 0%"></div>
          </div>
          <div class="detail-simple-item" style="margin-top: 10px;">
            <span>유지 진행</span>
            <strong id="learnHoldProgressText">0%</strong>
          </div>
          <ul class="learn-step-hints" id="learnStepHints"></ul>
          <div class="learn-step-checks" id="learnStepChecks"></div>
          <p class="muted learn-step-status" id="learnStepStatus">현재 step에서 취해야 할 자세가 여기에 표시됩니다.</p>
        </div>

        <!-- 운동 카운터 -->
        <div class="card counter-card">
          <div class="counter-row">
            <div class="counter-item">
              <span class="counter-value" id="repCount">0</span>
              <span class="counter-label" id="repCountLabel"><%= isLearnMode ? '현재 step' : (isPlankExercise ? '시간(초)' : '횟수') %></span>
            </div>
            <div class="counter-item">
              <span class="counter-value" id="setCount">1</span>
              <span class="counter-label" id="setCountLabel"><%= isLearnMode ? '전체 step' : '세트' %></span>
            </div>
          </div>
            <div class="progress-card" id="plankRuntimePanel" style="margin-top: 14px;" <%= isPlankExercise ? '' : 'hidden' %>>
              <span class="muted">플랭크 진행</span>
              <div class="progress">
                <div class="progress-bar" id="plankProgress" style="width: 0%"></div>
              </div>
              <div class="plank-runtime-grid" style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin-top: 10px;">
                <div class="detail-key-item">
                  <label>현재 구간</label>
                  <div id="plankCurrentHold">00:00</div>
                </div>
                <div class="detail-key-item">
                  <label>최고 기록</label>
                  <div id="plankBestHold">00:00</div>
                </div>
                <div class="detail-key-item">
                  <label>목표 시간</label>
                  <div id="plankTargetReadout">30초</div>
                </div>
              </div>
              <span class="muted" id="plankPhaseInfo" style="display: block; margin-top: 10px; font-size: 12px;">SETUP</span>
            </div>
          <% if (isRoutineMode && routine) { %>
            <div class="progress-card">
              <span class="muted">루틴 진행</span>
              <div class="progress">
                <div class="progress-bar" id="routineProgress" style="width: 0%"></div>
              </div>
              <span class="muted" id="routineStep">1 / <%= routine.routine_setup.length %> 운동</span>
            </div>
            <% } %>
        </div>

        <!-- 타이머 -->
        <div class="card timer-card">
          <div class="timer-display">
            <span class="timer-value" id="timerValue">00:00</span>
            <span class="timer-label" id="timerLabel"><%= isLearnMode ? '학습 시간' : (isPlankExercise ? '플랭크 시간' : '운동 시간') %></span>
          </div>
            <div class="progress-card" id="plankTimerPanel" style="margin-top: 14px;" <%= isPlankExercise ? '' : 'hidden' %>>
              <span class="muted">플랭크 상태</span>
              <div class="detail-simple-item" style="margin-top: 8px;">
                <span>진행 상태</span>
                <strong id="plankStateLabel">SETUP</strong>
              </div>
              <div class="detail-simple-item">
                <span>목표 달성</span>
                <strong id="plankGoalLabel">대기 중</strong>
              </div>
              <div class="detail-simple-item">
                <span>현재 구간 시간</span>
                <strong id="plankSegmentLabel">00:00</strong>
              </div>
            </div>
          <div class="rest-timer" id="restTimer" hidden>
            <span class="rest-value" id="restValue">30</span>
            <span class="rest-label">휴식 남음</span>
          </div>
        </div>

        <!-- 컨트롤 버튼 -->
        <div class="control-row">
          <button class="ghost full" id="pauseBtn" onclick="togglePause()" disabled>
            일시정지
          </button>
        </div>
        <div class="control-row">
          <button class="primary full" id="finishBtn" onclick="finishWorkout()" disabled>
            <%= isLearnMode ? '학습 종료' : '운동 종료' %>
          </button>
        </div>
      </aside>
    </div>
  </div>

  <% if (!isRoutineMode) { %>
    <div
      class="workout-onboarding-modal"
      id="workoutOnboardingModal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="onboardingSlideTitle"
      hidden
    >
      <div class="workout-onboarding-backdrop" data-onboarding-close="true"></div>
      <section class="workout-onboarding-card" aria-label="운동 시작 가이드">
        <header class="workout-onboarding-header">
          <div>
            <span class="workout-onboarding-eyebrow">운동 시작 가이드</span>
            <h3 id="onboardingSlideTitle">카메라 세팅법</h3>
          </div>
          <button
            type="button"
            class="icon workout-onboarding-close"
            id="onboardingCloseBtn"
            aria-label="온보딩 닫기"
          >×</button>
        </header>

        <div class="workout-onboarding-progress" id="onboardingProgress">1 / 4</div>

        <div class="workout-onboarding-image-shell">
          <img
            class="workout-onboarding-image"
            id="onboardingImage"
            alt="운동 가이드 이미지"
            hidden
          />
          <div class="workout-onboarding-image-placeholder" id="onboardingImagePlaceholder">
            <strong>가이드 이미지 준비 중</strong>
            <span>이미지가 추가되면 이 영역에 표시됩니다.</span>
          </div>
        </div>

        <ul class="workout-onboarding-bullets" id="onboardingSlideBullets"></ul>

        <footer class="workout-onboarding-actions">
          <button
            type="button"
            class="ghost workout-onboarding-arrow"
            id="onboardingPrevBtn"
            aria-label="이전 안내"
          >‹</button>
          <button
            type="button"
            class="primary workout-onboarding-next"
            id="onboardingNextBtn"
            aria-label="다음 안내"
          >›</button>
        </footer>
      </section>
    </div>
  <% } %>

  <!-- 종료 확인 모달 -->
  <div class="modal" id="exitModal" hidden>
    <div class="modal-content">
      <div class="modal-header">
        <h3>운동 종료</h3>
        <button class="icon" onclick="closeExitModal()">×</button>
      </div>
      <div class="modal-body">
        <p><%= isLearnMode ? '정말로 학습을 종료하시겠습니까?' : '정말로 운동을 종료하시겠습니까?' %></p>
        <p class="muted">현재까지의 기록이 저장됩니다.</p>
      </div>
      <div class="modal-actions">
        <button class="ghost" onclick="closeExitModal()">계속하기</button>
        <button class="danger" onclick="forceExit()">종료하기</button>
      </div>
    </div>
  </div>

  <script>
    const workoutData = {
      mode: '<%= mode %>',
      exercise: <%- JSON.stringify(currentExercise) %>,
      selectedView: '<%= defaultView %>',
      scoringProfile: <%- scoringProfile ? JSON.stringify(scoringProfile) : 'null' %>,
      plankTargetSec: null,
    <% if (isRoutineMode) { %>
      routine: <%- JSON.stringify(routine) %>,
      routineInstance: <%- JSON.stringify(routineInstance) %>,
    <% } else { %>
      routine: null,
      routineInstance: null,
    <% } %>
    };

    document.addEventListener('DOMContentLoaded', () => {
      initSession(workoutData).catch((err) => console.error('[Session] 초기화 실패:', err));
    });
  </script>

  <style>
    /* CSS flex/grid 설정이 hidden 속성을 덮어씌우는 문제 해결 */
    [hidden] {
      display: none !important;
    }
  </style>

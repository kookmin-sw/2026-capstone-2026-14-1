<div class="page active">
  <%
    const stripEmoji = (value, fallback = '') => {
      const safe = String(value || fallback || '');
      const stripped = safe
        .replace(/\p{Extended_Pictographic}/gu, '')
        .replace(/\s{2,}/g, ' ')
        .trim();
      return stripped || fallback;
    };

    const formatDurationValue = (totalSeconds) => {
      const safeSeconds = Math.max(0, Number(totalSeconds) || 0);
      const mins = Math.floor(safeSeconds / 60);
      const secs = safeSeconds % 60;
      return `${mins}분 ${secs}초`;
    };

    const resultSummary = stripEmoji(session.summary_feedback, '운동을 완료했습니다.');
    const totalReps = Math.max(0, Number(session.total_reps) || 0);
    const isLearnMode = session.mode === 'LEARN';
    const modeLabel = isLearnMode
      ? '학습'
      : (session.mode === 'ROUTINE' ? '루틴' : '자율');
    const totalSteps = Math.max(0, Number(session.total_result_value) || 0);
    const primaryCountLabel = isLearnMode ? '완료한 단계' : '총 횟수';
    const primaryCountValue = isLearnMode ? `${totalSteps}단계` : `${totalReps}회`;
  %>

  <section class="page-header">
    <div>
      <h1><%= isLearnMode ? '학습 완료' : '운동 완료' %></h1>
      <p class="muted"><%= session.exercise.name %> - <%= modeLabel %> 모드</p>
    </div>
    <div class="actions">
      <a href="/" class="primary">홈으로</a>
    </div>
  </section>

  <div class="grid two">
    <div class="card hero" style="align-items: center; text-align: center;">
      <h3>최종 점수</h3>
      <div class="score"><%= session.final_score || 0 %></div>
      <div class="summary-lines">
        <p><%= resultSummary %></p>
      </div>
      <% if (session.final_score >= 80) { %>
        <span class="badge" style="background: #22c55e;">우수</span>
      <% } else if (session.final_score >= 60) { %>
        <span class="badge" style="background: #eab308;">양호</span>
      <% } else { %>
        <span class="badge" style="background: #ef4444;">개선 필요</span>
      <% } %>
    </div>

    <div class="card">
      <h3>운동 요약</h3>
      <div class="stat-list">
        <div class="stat">
          <span>운동 모드</span>
          <strong><%= modeLabel %></strong>
        </div>
        <div class="stat">
          <span><%= primaryCountLabel %></span>
          <strong><%= primaryCountValue %></strong>
        </div>
        <div class="stat">
          <span><%= isLearnMode ? '학습 시간' : '운동 시간' %></span>
          <strong><%= formatDurationValue(session.duration_sec || 0) %></strong>
        </div>
      </div>
    </div>
  </div>

  <% if (session.session_snapshot_metric && session.session_snapshot_metric.length > 0) { %>
    <div class="card">
      <div class="card-header">
        <h3>항목별 점수</h3>
        <span class="muted">각 평가 항목별 평균 점수</span>
      </div>
      <ul class="detail-list">
        <% session.session_snapshot_metric.forEach((result) => { %>
          <li>
            <span><%= result.metric_name %></span>
            <strong><%= result.avg_score %>점</strong>
          </li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card">
    <div class="card-header">
      <h3>오늘의 운동</h3>
    </div>
    <div class="stat-list">
      <div class="stat">
        <span>오늘 총 운동 시간</span>
        <strong><%= totalTodayMinutes %>분</strong>
      </div>
    </div>
  </div>

  <div class="grid two">
    <div class="card">
      <h3><%= isLearnMode ? '실전으로 이어가기' : '다음 운동' %></h3>
      <p class="muted">
        <%= isLearnMode ? '배운 자세를 바로 자율 운동에서 이어서 연습해보세요.' : '다른 운동으로 계속 운동해보세요.' %>
      </p>
      <div class="card-actions" style="margin-top: auto;">
        <a href="/workout/free/<%= session.exercise.code %>" class="primary full">
          <%= isLearnMode ? '자율 운동 시작' : '이 운동 계속하기' %>
        </a>
        <a href="<%= isLearnMode ? '/workout/free' : '/routine' %>" class="ghost full">
          <%= isLearnMode ? '운동 목록 보기' : '내 루틴' %>
        </a>
      </div>
    </div>

    <div class="card">
      <h3><%= isLearnMode ? '다시 학습하기' : '자세 개선하기' %></h3>
      <p class="muted">
        <%= isLearnMode ? '같은 step 튜토리얼을 다시 진행하며 자세를 더 익혀보세요.' : '정확한 자세를 배워서 점수를 높여보세요.' %>
      </p>
      <a href="/learn/<%= session.exercise.code %>" class="ghost full">
        <%= isLearnMode ? `${session.exercise.name} 다시 배우기` : `${session.exercise.name} 배우기` %>
      </a>
    </div>
  </div>
</div>

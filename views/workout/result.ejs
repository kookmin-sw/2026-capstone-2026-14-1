<% const phaseDataset = session.detail && session.detail.phase_dataset ? session.detail.phase_dataset : null; %>
<% const phaseFrameCount = Array.isArray(phaseDataset && phaseDataset.feature_frames) ? phaseDataset.feature_frames.length : 0; %>
<% const phaseLabelCount = Array.isArray(phaseDataset && phaseDataset.labels) ? phaseDataset.labels.length : 0; %>

<div class="page active">
  <section class="page-header">
    <div>
      <h1>운동 완료!</h1>
      <p class="muted"><%= session.exercise.name %> - <%= session.mode === 'ROUTINE' ? '루틴' : '자율' %> 운동</p>
    </div>
    <div class="actions">
      <a href="/" class="primary">홈으로</a>
    </div>
  </section>

  <div class="grid two">
    <!-- 최종 점수 카드 -->
    <div class="card hero" style="align-items: center; text-align: center;">
      <h3>최종 점수</h3>
      <div class="score"><%= session.final_score || 0 %></div>
      <div class="summary-lines">
        <p><%= session.summary_feedback || '운동을 완료했습니다!' %></p>
      </div>
      <% if (session.final_score >= 80) { %>
        <span class="badge" style="background: #22c55e;">훌륭해요!</span>
      <% } else if (session.final_score >= 60) { %>
        <span class="badge" style="background: #eab308;">좋아요!</span>
      <% } else { %>
        <span class="badge" style="background: #ef4444;">분발하세요!</span>
      <% } %>
    </div>

    <!-- 운동 요약 -->
    <div class="card">
      <h3>운동 요약</h3>
      <div class="stat-list">
        <div class="stat">
          <span>운동 시간</span>
          <strong>
            <%
              const mins = Math.floor((session.duration_sec || 0) / 60);
              const secs = (session.duration_sec || 0) % 60;
            %>
            <%= mins %>분 <%= secs %>초
          </strong>
        </div>
        <div class="stat">
          <span>총 횟수</span>
          <strong>
            <% if ((session.result_basis === 'REPS' || session.total_result_unit === 'COUNT')) { %>
              <%= session.total_result_value || session.total_reps || 0 %>회
            <% } else { %>
              -
            <% } %>
          </strong>
        </div>
        <div class="stat">
          <span>선택 자세</span>
          <strong><%= session.selected_view || '-' %></strong>
        </div>
        <div class="stat">
          <span>운동 종류</span>
          <strong><%= session.exercise.name %></strong>
        </div>
        <div class="stat">
          <span>운동 모드</span>
          <strong><%= session.mode === 'ROUTINE' ? '루틴' : '자율' %></strong>
        </div>
      </div>
    </div>
  </div>

  <!-- 세부 점수 -->
  <% if (session.session_snapshot_metric && session.session_snapshot_metric.length > 0) { %>
    <div class="card">
      <div class="card-header">
        <h3>세부 점수</h3>
        <span class="muted">각 평가 항목별 점수</span>
      </div>
      <ul class="detail-list">
        <% session.session_snapshot_metric.forEach(result => { %>
          <li>
            <span><%= result.metric_name %></span>
            <strong><%= result.avg_score %>점</strong>
          </li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <% if (phaseDataset && phaseFrameCount > 0) { %>
    <div class="card">
      <div class="card-header">
        <h3>Phase 학습 데이터</h3>
        <span class="muted">세션 프레임 <%= phaseFrameCount %>개, 라벨 <span id="phaseLabelCount"><%= phaseLabelCount %></span>개</span>
      </div>
      <p class="muted">
        사람이 라벨링한 phase JSON을 붙여넣거나 업로드하면 이 세션을 바로 학습용 데이터셋으로 내보낼 수 있습니다.
        지원 형식은 `[{"frame_index": 12, "phase": "BOTTOM"}]` 또는 `{ "labels": [...] }` 입니다.
      </p>
      <div class="grid two" style="margin-top: 16px;">
        <div>
          <label for="phaseLabelsJson"><strong>라벨 JSON</strong></label>
          <textarea
            id="phaseLabelsJson"
            class="form-textarea"
            rows="10"
            placeholder='[{"frame_index": 10, "phase": "DESCENT"}, {"frame_index": 11, "phase": "BOTTOM"}]'
          ><%= phaseLabelCount > 0 ? JSON.stringify(phaseDataset.labels, null, 2) : '' %></textarea>
        </div>
        <div>
          <div class="stat-list">
            <div class="stat">
              <span>상태</span>
              <strong id="phaseLabelStatus"><%= phaseLabelCount > 0 ? '라벨 저장됨' : '라벨 대기' %></strong>
            </div>
            <div class="stat">
              <span>샘플 간격</span>
              <strong><%= phaseDataset.sample_ms || 200 %>ms</strong>
            </div>
          </div>
          <div class="card-actions" style="margin-top: 16px;">
            <input type="file" id="phaseLabelsFile" accept="application/json,.json" />
            <button type="button" class="ghost full" id="loadPhaseLabelsBtn">파일 불러오기</button>
            <button type="button" class="primary full" id="savePhaseLabelsBtn">라벨 저장</button>
            <button type="button" class="ghost full" id="downloadPhaseDatasetBtn">학습 JSON 다운로드</button>
          </div>
          <p class="muted" id="phaseDatasetMessage" style="margin-top: 12px;"></p>
        </div>
      </div>
    </div>
  <% } %>

  <!-- 오늘의 운동 요약 -->
  <div class="card">
    <div class="card-header">
      <h3>오늘의 운동</h3>
    </div>
    <div class="stat-list">
      <div class="stat">
        <span>오늘 총 운동 시간</span>
        <strong><%= totalTodayMinutes %>분</strong>
      </div>
    </div>
  </div>

  <!-- 추천 액션 -->
  <div class="grid two">
    <div class="card">
      <h3>🏋️ 다음 운동</h3>
      <p class="muted">다른 운동으로 계속 운동하세요!</p>
      <div class="card-actions" style="margin-top: auto;">
        <a href="/workout/free" class="ghost full">자율 운동</a>
        <a href="/routine" class="primary full">내 루틴</a>
      </div>
    </div>

    <div class="card">
      <h3>📚 자세 개선하기</h3>
      <p class="muted">정확한 자세를 배워서 점수를 높여보세요!</p>
      <a href="/learn/<%= session.exercise.code %>" class="ghost full">
        <%= session.exercise.name %> 배우기 →
      </a>
    </div>
  </div>
</div>

<% if (phaseDataset && phaseFrameCount > 0) { %>
  <script>
    (() => {
      const sessionId = '<%= session.session_id %>';
      const textarea = document.getElementById('phaseLabelsJson');
      const fileInput = document.getElementById('phaseLabelsFile');
      const loadBtn = document.getElementById('loadPhaseLabelsBtn');
      const saveBtn = document.getElementById('savePhaseLabelsBtn');
      const downloadBtn = document.getElementById('downloadPhaseDatasetBtn');
      const messageEl = document.getElementById('phaseDatasetMessage');
      const statusEl = document.getElementById('phaseLabelStatus');
      const countEl = document.getElementById('phaseLabelCount');

      const setMessage = (text, isError = false) => {
        messageEl.textContent = text || '';
        messageEl.style.color = isError ? '#ef4444' : '#64748b';
      };

      loadBtn.addEventListener('click', async () => {
        const file = fileInput.files && fileInput.files[0];
        if (!file) {
          setMessage('먼저 JSON 파일을 선택하세요.', true);
          return;
        }

        try {
          textarea.value = await file.text();
          setMessage('파일 내용을 불러왔습니다.');
        } catch (error) {
          setMessage('파일을 읽지 못했습니다.', true);
        }
      });

      saveBtn.addEventListener('click', async () => {
        let payload;
        try {
          payload = JSON.parse(textarea.value || '[]');
        } catch (error) {
          setMessage('유효한 JSON이 아닙니다.', true);
          return;
        }

        saveBtn.disabled = true;
        setMessage('라벨을 저장하는 중입니다...');

        try {
          const response = await fetch(`/api/workout/session/${sessionId}/phase-labels`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(data.error || data.message || '라벨 저장 실패');
          }

          statusEl.textContent = '라벨 저장됨';
          countEl.textContent = data.labeling?.labeled_frames || 0;
          setMessage(`라벨 ${data.labeling?.labeled_frames || 0}개를 저장했습니다.`);
        } catch (error) {
          setMessage(error.message || '라벨 저장에 실패했습니다.', true);
        } finally {
          saveBtn.disabled = false;
        }
      });

      downloadBtn.addEventListener('click', async () => {
        downloadBtn.disabled = true;
        setMessage('학습 JSON을 준비하는 중입니다...');

        try {
          const response = await fetch(`/api/workout/session/${sessionId}/phase-dataset`);
          const data = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(data.error || data.message || '다운로드 준비 실패');
          }

          const blob = new Blob([JSON.stringify(data.dataset, null, 2)], { type: 'application/json' });
          const url = URL.createObjectURL(blob);
          const anchor = document.createElement('a');
          anchor.href = url;
          anchor.download = `phase-dataset-${sessionId}.json`;
          document.body.appendChild(anchor);
          anchor.click();
          anchor.remove();
          URL.revokeObjectURL(url);
          setMessage('학습 JSON을 다운로드했습니다.');
        } catch (error) {
          setMessage(error.message || '다운로드에 실패했습니다.', true);
        } finally {
          downloadBtn.disabled = false;
        }
      });
    })();
  </script>
<% } %>
